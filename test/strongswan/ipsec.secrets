# Server RSA private key + the EAP-MSCHAPv2 credential the client authenticates
# with. Change the username/password (and pass the same to go-ipsec).
: RSA serverKey.pem

testuser : EAP "testpass"

# Pre-shared key for the `rw-psk` conn, scoped to the server and client IKE
# identities. Pass the same value to go-ipsec as Config.PSK (LocalID @client.test).
@vpn.example.com @client.test : PSK "test-preshared-key"
